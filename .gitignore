main
main.exe
coden
coden-*
*.exe

# Go test/coverage artifacts
*.test
*.out
go.work
go.work.sum
vendor/

# Secrets and credentials
.env
.env.*
*.key
*.pem
*.p12
credentials.json
secrets.yaml
secrets.yml

# macOS metadata
.DS_Store
._*
.Spotlight-V100
.Trashes

# Editor / IDE
.idea/
.vscode/
*.swp
*.swo
